# Sepolia deployment (used by Hardhat at repo root)
# Copy to contracts/.env — hardhat.config.js loads contracts/.env first.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# Etherscan — required for `npm run verify:sepolia`
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional: reuse existing USDC on Sepolia instead of deploying MockUSDC
# USDC_ADDRESS=0x...

# Backend contract addresses (Sepolia demo — update after `npm run deploy:sepolia`)
# MOCK_USDC_ADDRESS=0x2293193Eaa5CE5253d5e081046a06dB077f26f8e
# REPUTATION_STORE_ADDRESS=0x9B0041E95fc236cB296296BE6E4dD6cdFc4eF3Ff
# PLATFORM_TREASURY_ADDRESS=0xd752C7C94e6571e9781aB8dAc54c749f33BD09Fe
# JOB_REGISTRY_ADDRESS=0xE5425cFE21BAe73d54138Bb290B671bF4c55FBC9
# ARBITRATOR_PANEL_ADDRESS=0x96eCEfBd86dF049994fd411689566B126afcd0EB
# ESCROW_VAULT_ADDRESS=0xeE67C7bdC2679aa86b6eA4b7311a74B4c8bf6DD3
